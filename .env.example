# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT TEMPLATE — copy to .env and fill in. NEVER commit the real .env.
#   cp .env.example .env
# Bun auto-loads .env; no dotenv step required.
# ─────────────────────────────────────────────────────────────────────────────

# --- Discord (required) ---
CLIENT_TOKEN=your_bot_token            # Bot token (Developer Portal → Bot)
DISCORD_APP_ID=your_application_id      # Application (client) ID
GUILD_ID=your_dev_guild_id             # Dev guild for command registration

# --- AI assistant (Groq) ---
GROQ_API_KEY=your_groq_key
AI_MODEL_REFINE=llama-3.1-8b-instant
AI_MODEL_ANSWER=llama-3.1-8b-instant
AI_MAX_TOKENS=500

# --- Feature channels / roles ---
STAFF_ROLE_ID=your_staff_role_id
LOGS_CHANNEL_ID=your_logs_channel_id   # Moderation audit log + protection logs
ASK_CHANNEL_ID=your_ask_channel_id
REPORT_CHANNEL_ID=your_report_channel_id
WELCOME_CHANNEL_ID=your_welcome_channel_id
VERIFY_CHANNEL_ID=your_verify_channel_id
MEMBER_ROLE_ID=your_member_role_id
AUTO_HELP_CHANNEL_ID=your_auto_help_channel_id
FEEDBACK_CHANNEL_ID=your_feedback_channel_id

# --- Anti-spam / protection (optional overrides; defaults exist in code) ---
# SPAM_THRESHOLD=5
# SPAM_INTERVAL=5000
# SPAM_TIMEOUT_DURATION=600000

# --- FalloutChat in-game relay (src/utils/ChatRelay.js) ---
# Set ENABLED=false to disable. Reuse WS_URL / BOT_SECRET / channel from the
# existing chat server so in-game ↔ Discord chat keeps working.
CHAT_RELAY_ENABLED=true
CHAT_WS_URL=wss://your-chat-server.example/ws
CHAT_RELAY_CHANNEL_ID=                 # Discord channel mirrored to the game
CHAT_BOT_SECRET=                       # must match the chat server's BOT_SECRET
CHAT_ADMIN_ROLE_ID=                    # role allowed to run relay mod commands (optional)
